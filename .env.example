# ===================================
# ASTROMAN Sky Intelligence System
# Environment Variables
# ===================================

# --- Application ---
APP_NAME=ASTROMAN Sky Intelligence
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=your-secret-key-change-this-in-production
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Admin Credentials ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-secure-password

# --- Location (Tbilisi) ---
LOCATION_LAT=41.7151
LOCATION_LON=44.8271
LOCATION_NAME=თბილისი
TIMEZONE=Asia/Tbilisi

# --- OpenWeather API ---
OPENWEATHER_API_KEY=your-openweather-api-key

# --- Email Configuration ---
# Choose: "smtp" or "sendgrid"
EMAIL_PROVIDER=smtp

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=sky@astroman.ge
SMTP_FROM_NAME=ASTROMAN Sky Intelligence

# SendGrid Settings
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=sky@astroman.ge

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ENABLED=false

# --- Scheduler ---
# Daily email send time (24h format, Tbilisi timezone)
DAILY_SEND_HOUR=17
DAILY_SEND_MINUTE=0

# Weekly summary day (0=Monday, 6=Sunday)
WEEKLY_SUMMARY_DAY=0

# --- ASTROMAN Store ---
ASTROMAN_STORE_URL=https://astroman.ge
ASTROMAN_PRODUCTS_URL=https://astroman.ge/products

# --- WooCommerce API (Feature 3) ---
# Leave empty to use fallback product catalog
WOO_API_URL=https://astroman.ge/wp-json/wc/v3
WOO_CONSUMER_KEY=ck_your_woocommerce_consumer_key
WOO_CONSUMER_SECRET=cs_your_woocommerce_consumer_secret
WOO_CACHE_TTL_SECONDS=600

# --- Store Physical Location (Feature 5) ---
STORE_NAME=ASTROMAN
STORE_ADDRESS=თბილისი, საქართველო
STORE_CITY=თბილისი
STORE_COUNTRY=საქართველო
STORE_GOOGLE_MAPS_URL=https://maps.google.com/?q=ASTROMAN+Tbilisi
STORE_PHONE=+995-XXX-XXX-XXX
STORE_EMAIL=info@astroman.ge
STORE_WORKING_HOURS_WEEKDAY=10:00–20:00
STORE_WORKING_HOURS_WEEKEND=11:00–18:00
STORE_INSTAGRAM=https://instagram.com/astroman.ge
STORE_FACEBOOK=https://facebook.com/astroman.ge

# --- Notifications (Feature 6) ---
NOTIFICATIONS_ENABLED=false
CLEAR_SKY_ALERT_THRESHOLD=15
PLANET_RISE_ALERT_ENABLED=false

# --- Database ---
DATABASE_URL=sqlite:///./astroman.db
